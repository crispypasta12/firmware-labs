---
import SiteLayout from "../layouts/SiteLayout.astro";
import { featuredLabNums, labByNum, labsForTrack, tracks } from "../lib/labs";

const featured = featuredLabNums.map((num) => labByNum(num)).filter(Boolean);
---

<SiteLayout title="Firmware Labs">
  <div class="site-kicker">Interactive firmware labs</div>
  <h1 class="site-title">Practice the failure modes that make firmware hard.</h1>
  <p class="site-copy">
    Firmware Labs is organized by engineering track. Each lab is a focused simulator for a concrete debugging,
    architecture, timing, or wireless behavior.
  </p>

  <section class="site-section" aria-labelledby="deck-title">
    <h2 id="deck-title" class="site-kicker">Practice deck</h2>
    <div class="site-grid">
      <a class="site-card" href="/deck">
        <h3>Embedded fundamentals drill</h3>
        <p>Self-grade core firmware concepts with filters, keyboard shortcuts, and a retry queue.</p>
        <div class="site-meta">
          <span>20 cards</span>
          <span>Review draft</span>
        </div>
      </a>
    </div>
  </section>

  <section class="site-section" aria-labelledby="tracks-title">
    <h2 id="tracks-title" class="site-kicker">Tracks</h2>
    <div class="site-grid">
      {tracks.map((track) => {
        const trackLabs = labsForTrack(track.slug);
        return (
          <a class="site-card" href={`/track/${track.slug}`}>
            <h3>{track.title}</h3>
            <p>{track.summary}</p>
            <div class="site-meta">
              <span>{trackLabs.length} labs</span>
              <span data-progress-track={track.slug} data-progress-labs={trackLabs.map((lab) => lab.slug).join(",")}>
                0/{trackLabs.length}
              </span>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <section class="site-section" aria-labelledby="featured-title">
    <h2 id="featured-title" class="site-kicker">Featured labs</h2>
    <div class="site-list">
      {featured.map((lab) => lab && (
        <a class="site-lab-row" href={`/lab/${lab.slug}`}>
          <span class="site-num">LAB {lab.num}</span>
          <span>
            <h2>{lab.title}</h2>
            <p>{lab.description}</p>
          </span>
          <span class="site-check" data-progress-lab={lab.slug}>Not complete</span>
        </a>
      ))}
    </div>
  </section>
</SiteLayout>
