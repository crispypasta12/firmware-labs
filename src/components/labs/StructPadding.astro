<!-- LAB 07 — extracted verbatim from golden/ti_concepts_lab.html.
     Only change: element ids prefixed with the lab slug (struct-padding-). -->
<div class="scope">
  <div class="members" id="struct-padding-padMembers"></div>
  <label class="sw" style="margin-bottom:10px"><input type="checkbox" id="struct-padding-padPacked"> <code>__attribute__((packed))</code></label>
  <div class="bytegrid" id="struct-padding-padGrid"></div>
  <div class="statline"><span>sizeof(struct): <span class="v" id="struct-padding-padSize">—</span> bytes</span><span>padding: <span class="v" id="struct-padding-padWaste">—</span> bytes</span></div>
  <div class="narr" id="struct-padding-padNarr"></div>
</div>

<style is:global>
/* struct */
.members{display:flex;flex-direction:column;gap:6px;margin-bottom:12px}
.member{display:flex;align-items:center;gap:8px;border:1px solid var(--border2);border-radius:4px;padding:6px 10px;background:rgba(17,20,24,.85);font-family:'IBM Plex Mono',monospace;font-size:12px}
.member .mv{margin-left:auto;display:flex;gap:4px}
.member button{padding:2px 8px;font-size:11px}
.bytegrid{display:grid;grid-template-columns:repeat(8,1fr);gap:4px;max-width:480px}
.byte{height:34px;border-radius:3px;display:flex;align-items:center;justify-content:center;font-family:'IBM Plex Mono',monospace;font-size:10px;border:1px solid var(--border2);color:#0a0c0f;font-weight:600}
.byte.pad{background:repeating-linear-gradient(45deg,#2a3340,#2a3340 4px,#181d23 4px,#181d23 8px);color:var(--dim);font-weight:400}
/* vol2 .statline variant (tokens.css carries the vol2b/vol4 12px margin) */
.statline{margin-top:26px}
</style>

<script is:inline>
/* ===== 7. STRUCT PADDING ===== */
(function(){
  let members=[{n:'flags',t:'uint8_t',sz:1,col:'#ffb454'},{n:'timestamp',t:'uint32_t',sz:4,col:'#00d4aa'},{n:'length',t:'uint16_t',sz:2,col:'#a080e0'},{n:'type',t:'uint8_t',sz:1,col:'#0099cc'}];
  const list=document.getElementById('struct-padding-padMembers'),grid=document.getElementById('struct-padding-padGrid');
  function layout(){
    const packed=document.getElementById('struct-padding-padPacked').checked;
    let off=0,bytes=[],maxA=1;
    members.forEach(m=>{
      const a=packed?1:m.sz;maxA=Math.max(maxA,a);
      while(off%a!==0){bytes.push({pad:true});off++}
      for(let k=0;k<m.sz;k++){bytes.push({m});off++}
    });
    if(!packed){while(off%maxA!==0){bytes.push({pad:true});off++}}
    return {bytes,size:off};
  }
  function draw(){
    list.innerHTML='';
    members.forEach((m,i)=>{
      const d=document.createElement('div');d.className='member';
      d.innerHTML='<span style="width:12px;height:12px;border-radius:2px;background:'+m.col+'"></span><span>'+m.t+' '+m.n+';</span><span style="color:var(--muted)">'+m.sz+'B</span><span class="mv"></span>';
      const mv=d.querySelector('.mv');
      const up=document.createElement('button');up.textContent='▲';up.disabled=i===0;up.onclick=()=>{[members[i-1],members[i]]=[members[i],members[i-1]];draw()};
      const dn=document.createElement('button');dn.textContent='▼';dn.disabled=i===members.length-1;dn.onclick=()=>{[members[i+1],members[i]]=[members[i],members[i+1]];draw()};
      mv.append(up,dn);list.appendChild(d);
    });
    const {bytes,size}=layout();
    grid.innerHTML='';
    bytes.forEach((b,i)=>{
      const d=document.createElement('div');d.className='byte'+(b.pad?' pad':'');
      d.style.background=b.pad?'':b.m.col;
      d.textContent=b.pad?'pad':b.m.n[0].toUpperCase();
      d.title=b.pad?'padding byte (offset '+i+')':b.m.t+' '+b.m.n+' (offset '+i+')';
      grid.appendChild(d);
    });
    const waste=bytes.filter(b=>b.pad).length;
    document.getElementById('struct-padding-padSize').textContent=size;
    document.getElementById('struct-padding-padWaste').textContent=waste;
    document.getElementById('struct-padding-padNarr').textContent=document.getElementById('struct-padding-padPacked').checked
      ?'Packed: no padding, exact wire layout — but uint32_t may land on an odd offset → unaligned access (slow on M3/M4, HardFault on M0).'
      :(waste===0?'Zero padding — this ordering is optimal (largest members first).':'The compiler inserted '+waste+' padding byte(s) to satisfy alignment. Try reordering: largest first.');
  }
  document.getElementById('struct-padding-padPacked').onchange=draw;
  draw();
})();
</script>
