<!-- LAB 01 - extracted verbatim from golden/ti_concepts_lab.html.
     Only change: element ids prefixed with the lab slug (race-condition-). -->
<div class="scope">
  <div class="race-grid">
    <div class="race-task"><h4 style="color:var(--teal)">TASK A</h4><div id="race-condition-taskA"></div></div>
    <div class="race-task"><h4 style="color:var(--purple)">TASK B (preempts A)</h4><div id="race-condition-taskB"></div></div>
  </div>
  <div class="race-state">
    <span>counter (memory): <span class="v" id="race-condition-rcMem">5</span></span>
    <span>A's register: <span class="v" id="race-condition-rcRA">-</span></span>
    <span>B's register: <span class="v" id="race-condition-rcRB">-</span></span>
    <span id="race-condition-rcLost"></span>
  </div>
  <div class="narr" id="race-condition-rcNarr">Two tasks each call counter++ once. Expected result: 7. Press Step.</div>
</div>
<div class="btnrow">
  <button class="primary" id="race-condition-rcStep">Step ▸</button>
  <button id="race-condition-rcReset">Reset</button>
</div>

<style is:global>
/* race stepper */
.race-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.race-task{border:1px solid var(--border2);border-radius:6px;background:rgba(17,20,24,.85);padding:10px 12px}
.race-task h4{font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.06em;margin-bottom:8px}
.race-line{font-family:'IBM Plex Mono',monospace;font-size:11.5px;color:var(--dim);padding:3px 8px;border-radius:3px;border-left:2px solid transparent}
.race-line.active{color:var(--text);background:rgba(0,212,170,.1);border-left-color:var(--teal)}
.race-line.done{color:var(--muted)}
.race-state{display:flex;gap:18px;margin-top:12px;font-family:'IBM Plex Mono',monospace;font-size:12px;flex-wrap:wrap}
.race-state .v{color:var(--amber);font-weight:600}
.race-state .lostflag{color:var(--red);font-weight:600}
@media(max-width:700px){.race-grid{grid-template-columns:1fr}}
</style>

<script is:inline>
/* ===== 1. RACE ===== */
(function(){
  const linesA=['LOAD  r1, [counter]   ; r1 = 5','ADD   r1, r1, #1       ; r1 = 6','STORE [counter], r1    ; mem = 6'];
  const linesB=['LOAD  r2, [counter]   ; r2 = 5','ADD   r2, r2, #1       ; r2 = 6','STORE [counter], r2    ; mem = 6'];
  const A=document.getElementById('race-condition-taskA'),B=document.getElementById('race-condition-taskB');
  linesA.forEach(t=>{const d=document.createElement('div');d.className='race-line';d.textContent=t;A.appendChild(d)});
  linesB.forEach(t=>{const d=document.createElement('div');d.className='race-line';d.textContent=t;B.appendChild(d)});
  const la=[...A.children], lb=[...B.children];
  // schedule: A0, (preempt) B0,B1,B2, (resume) A1, A2
  const steps=[
    {l:la[0],mem:5,ra:'5',rb:'-',n:'Task A loads counter (5) into its register... and is preempted right here.'},
    {l:lb[0],mem:5,ra:'5',rb:'5',n:'Task B runs. It loads counter - still 5. A\'s increment hasn\'t been stored yet.'},
    {l:lb[1],mem:5,ra:'5',rb:'6',n:'B increments its private copy to 6.'},
    {l:lb[2],mem:6,ra:'5',rb:'6',n:'B stores 6 to memory. B\'s increment is complete.'},
    {l:la[1],mem:6,ra:'6',rb:'6',n:'A resumes - but it still holds the STALE value 5, and increments it to 6.'},
    {l:la[2],mem:6,ra:'6',rb:'6',n:'A stores 6 - overwriting B\'s work. Two increments, counter went 5 → 6. ONE UPDATE LOST.',lost:true}
  ];
  let i=0;
  const mem=document.getElementById('race-condition-rcMem'),ra=document.getElementById('race-condition-rcRA'),rb=document.getElementById('race-condition-rcRB'),narr=document.getElementById('race-condition-rcNarr'),lost=document.getElementById('race-condition-rcLost');
  document.getElementById('race-condition-rcStep').onclick=()=>{
    if(i>=steps.length)return;
    [...la,...lb].forEach(x=>x.classList.remove('active'));
    if(i>0)steps[i-1].l.classList.add('done');
    const s=steps[i]; s.l.classList.add('active');
    mem.textContent=s.mem; ra.textContent=s.ra; rb.textContent=s.rb; narr.textContent=s.n;
    if(s.lost)lost.innerHTML='<span class="lostflag">⚠ LOST UPDATE — expected 7</span>';
    i++;
  };
  document.getElementById('race-condition-rcReset').onclick=()=>{
    i=0;[...la,...lb].forEach(x=>x.classList.remove('active','done'));
    mem.textContent='5';ra.textContent='-';rb.textContent='-';lost.textContent='';
    narr.textContent='Two tasks each call counter++ once. Expected result: 7. Press Step.';
  };
})();
</script>
