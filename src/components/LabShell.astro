---
// Renders the shared .lab chrome (head / why / takeaway) around a lab body.
// why/takeaway/title accept HTML (golden copy contains <code>, <b> etc.).
import { genericizePageCopy } from "../lib/pageCopy";

interface Props {
  num: string;
  title: string;
  tag: string;
  why: string;
  /** optional — some golden labs (e.g. LAB 08) have no takeaway box */
  takeaway?: string;
  id?: string;
}
const { num, title, tag, why, takeaway, id } = Astro.props;
const safeWhy = genericizePageCopy(why);
const safeTakeaway = takeaway ? genericizePageCopy(takeaway) : undefined;
---
<section class="lab" id={id}>
  <div class="lab-head">
    <span class="lab-num">{num}</span>
    <span class="lab-title" set:html={title} />
    <span class="lab-tag">{tag}</span>
  </div>
  <div class="lab-body">
    <div class="lab-why" set:html={safeWhy} />
    <slot />
    {safeTakeaway && <div class="takeaway" set:html={safeTakeaway} />}
  </div>
</section>
