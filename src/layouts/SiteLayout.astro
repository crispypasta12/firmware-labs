---
import "../styles/tokens.css";
import Analytics from "@vercel/analytics/astro";

interface Props {
  title: string;
  description?: string;
  ogType?: string;
}
const {
  title,
  description = "Interactive simulators and flashcards for practicing firmware debugging, architecture, timing, and wireless engineering judgment.",
  ogType = "website",
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
const ogImage = new URL("/og.svg", Astro.site ?? Astro.url.origin).toString();
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0c0f" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-topbar">
      <a class="site-brand" href="/">Firmware Labs</a>
      <nav class="site-nav" aria-label="Primary">
        <a href="/">Tracks</a>
        <a href="/deck">Deck</a>
      </nav>
    </header>
    <main class="site-wrap">
      <slot />
    </main>
    <Analytics />
    <script>
      import { setupProgressControls } from "../lib/progress";
      setupProgressControls();

      const topbar = document.querySelector<HTMLElement>(".site-topbar");
      if (topbar) {
        const update = () => {
          topbar.dataset.scrolled = window.scrollY > 8 ? "true" : "false";
        };
        update();
        window.addEventListener("scroll", update, { passive: true });
      }
    </script>
  </body>
</html>

<style is:global>
  .site-topbar{
    position:sticky;top:0;z-index:80;display:flex;align-items:center;justify-content:space-between;gap:16px;
    padding:14px 24px;border-bottom:1px solid var(--border);background:rgba(10,12,15,.78);
    backdrop-filter:blur(14px) saturate(1.3);-webkit-backdrop-filter:blur(14px) saturate(1.3)
  }
  .site-topbar::after{
    content:"";position:absolute;left:0;right:0;bottom:-1px;height:1px;
    background:linear-gradient(90deg,transparent,var(--teal),transparent);
    opacity:0;transition:opacity .3s ease
  }
  .site-topbar[data-scrolled="true"]::after{opacity:.5}
  .site-brand{
    display:inline-flex;align-items:center;gap:8px;
    font-family:'IBM Plex Mono',monospace;font-size:13px;font-weight:600;color:var(--teal);text-decoration:none;letter-spacing:.06em;text-transform:uppercase
  }
  .site-brand::before{
    content:"";width:6px;height:6px;border-radius:50%;background:var(--teal);
    box-shadow:0 0 8px var(--teal);animation:site-led 3s ease-in-out infinite
  }
  @keyframes site-led{50%{opacity:.5}}
  .site-nav{display:flex;gap:10px;align-items:center}
  .site-nav a{font-family:'IBM Plex Mono',monospace;font-size:11px;color:#8b98a8;text-decoration:none;border:1px solid var(--border2);border-radius:4px;padding:5px 9px}
  .site-nav a:hover{color:var(--teal);border-color:var(--teal)}
  .site-wrap{max-width:1040px;margin:0 auto;padding:24px}
  .site-kicker{font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--amber);letter-spacing:.08em;text-transform:uppercase;margin-bottom:8px}
  .site-title{font-size:28px;line-height:1.15;margin:0 0 10px}
  .site-copy{color:#8b98a8;font-size:14px;max-width:760px}
  .site-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:12px;margin-top:22px}
  .site-card{border:1px solid var(--border);border-radius:8px;background:var(--bg2);padding:14px;text-decoration:none;color:inherit;display:flex;flex-direction:column;gap:8px;min-height:140px}
  .site-card:hover{border-color:var(--teal)}
  .site-card h2,.site-card h3{font-size:15px;line-height:1.25;margin:0;color:var(--text)}
  .site-card p{font-size:12px;color:#8b98a8;line-height:1.6;margin:0}
  .site-meta{font-family:'IBM Plex Mono',monospace;font-size:10px;color:#8b98a8;display:flex;gap:10px;flex-wrap:wrap;margin-top:auto}
  .site-section{margin-top:30px}
  .site-list{display:grid;gap:8px;margin-top:14px}
  .site-lab-row{display:grid;grid-template-columns:auto 1fr auto;gap:12px;align-items:center;border:1px solid var(--border);border-radius:8px;background:var(--bg2);padding:12px;text-decoration:none;color:inherit}
  .site-lab-row:hover{border-color:var(--teal)}
  .site-num{font-family:'IBM Plex Mono',monospace;font-size:11px;color:#8b98a8}
  .site-lab-row h2{font-size:14px;margin:0 0 3px}
  .site-lab-row p{font-size:12px;color:#8b98a8;margin:0}
  .site-check{font-family:'IBM Plex Mono',monospace;font-size:10px;color:#8b98a8;border:1px solid var(--border2);border-radius:4px;padding:4px 7px}
  .site-check[data-done="true"]{color:var(--green);border-color:rgba(80,200,120,.5)}
  @media(max-width:700px){
    .site-topbar{padding:12px 16px}
    .site-wrap{padding:18px}
    .site-title{font-size:24px}
    .site-lab-row{grid-template-columns:1fr}
  }
</style>
